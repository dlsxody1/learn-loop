{
  "expo": {
    "name": "LearnLoop",
    "slug": "learnloop",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "learnloop",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learnloop.app"
    },
    "android": {
      "package": "com.learnloop.app",
      "adaptiveIcon": {
        "backgroundColor": "#0066cc",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0066cc"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
